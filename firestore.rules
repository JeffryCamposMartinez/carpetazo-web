rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNCIONES DE AYUDA (HELPER FUNCTIONS)
    // ==========================================
    function isAuth() {
      return request.auth != null;
    }
    
    function isTienda() {
      return isAuth() && request.auth.token.rol == 'tienda';
    }
    
    // ==========================================
    // REGLAS PARA USUARIOS
    // ==========================================
    match /users/{userId} {
      // Permitir lectura pública para poder ver el perfil de los vendedores
      allow read: if true;
      // Solo el dueño puede modificar su perfil
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ==========================================
    // REGLAS PARA CARPETAS (CATÁLOGOS)
    // ==========================================
    match /folders/{folderId} {
      // Leer: Cualquiera si la carpeta es pública. Si no, solo el dueño.
      allow read: if (resource.data.isPublic == true) || (isAuth() && resource.data.userId == request.auth.uid);
      
      // Crear: Solo usuarios logueados, y el userId debe ser el de ellos mismos.
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      
      // Modificar/Borrar: Solo el dueño de la carpeta.
      // ADEMÁS: Permitir a cualquier visitante incrementar los contadores de visitas.
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weeklyVisits', 'totalVisits', 'lastVisitWeek']));
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      
      
      // ----------------------------------------
      // SUB-COLECCIÓN: CARTAS (cards)
      // ----------------------------------------
      match /cards/{cardId} {
        // Leer: Igual que la carpeta padre. Si es pública, todos leen.
        allow read: if get(/databases/$(database)/documents/folders/$(folderId)).data.isPublic == true ||
                       (isAuth() && get(/databases/$(database)/documents/folders/$(folderId)).data.userId == request.auth.uid);
        
        // Escribir: Solo el dueño de la carpeta puede añadir/editar cartas con validación.
        allow create, update: if isAuth() 
                              && get(/databases/$(database)/documents/folders/$(folderId)).data.userId == request.auth.uid
                              && request.resource.data.price is number 
                              && request.resource.data.price >= 0
                              && request.resource.data.stock is number 
                              && request.resource.data.stock >= 0;
                              
        allow delete: if isAuth() && get(/databases/$(database)/documents/folders/$(folderId)).data.userId == request.auth.uid;
      }
    }

    // ==========================================
    // ÓRDENES Y PEDIDOS (Colección Raíz)
    // ==========================================
    match /orders/{orderId} {
      // El vendedor puede leer, actualizar o borrar órdenes que le pertenecen
      allow read, update, delete: if isAuth() && resource.data.sellerId == request.auth.uid;
      
      // Cualquier persona puede crear un pedido (compras por WhatsApp) pero con validación
      allow create: if true 
                    && request.resource.data.keys().hasAll(['sellerId', 'items', 'total', 'status', 'buyerName'])
                    && request.resource.data.total is number 
                    && request.resource.data.total > 0
                    && request.resource.data.status == 'pending'
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0;
    }

    // ==========================================
    // HISTORIAL DE VENTAS (Colección Raíz)
    // ==========================================
    match /history/{historyId} {
      // Solo el vendedor puede acceder a su historial de ventas
      allow read, write: if isAuth() && resource.data.sellerId == request.auth.uid;
    }

    // ==========================================
    // RESEÑAS (REVIEWS)
    // ==========================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.reviewerId == request.auth.uid
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string;
      allow update: if isAuth() && resource.data.reviewerId == request.auth.uid
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string;
      allow delete: if isAuth() && resource.data.reviewerId == request.auth.uid;
    }

    // ==========================================
    // CHATS INTERNOS
    // ==========================================
    match /chats/{chatId} {
      allow read, update: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, update: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuth() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.senderId == request.auth.uid;
      }
    }
    
    // ==========================================
    // CIERRE DE SEGURIDAD GLOBAL
    // ==========================================
    // Si alguien intenta acceder a una ruta que no especificamos arriba, DENEGAR por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
